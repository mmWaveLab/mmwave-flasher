import { LineEdit, ScrollView } from "std-widgets.slint";

component MiniButton inherits Rectangle {
    in property <string> label;
    in property <bool> enabled: true;
    in property <bool> active: false;
    callback clicked;

    height: 32px;
    border-radius: 8px;
    background: !root.enabled ? #f7f3f5 : root.active ? #ffe5ed : touch.pressed ? #ffd7e3 : touch.has-hover ? #fff1f6 : #ffffff;
    border-width: 1px;
    border-color: root.active ? #ff9bb8 : #efdfe6;
    opacity: root.enabled ? 1.0 : 0.55;
    animate background { duration: 100ms; easing: ease-out; }

    touch := TouchArea {
        enabled: root.enabled;
        mouse-cursor: root.enabled ? pointer : default;
        clicked => { root.clicked(); }
    }

    Text {
        text: root.label;
        color: root.enabled ? #55394a : #a2969e;
        font-size: 12px;
        font-weight: 760;
        horizontal-alignment: center;
        vertical-alignment: center;
        overflow: elide;
    }
}

component MiniToggle inherits Rectangle {
    in-out property <bool> checked;
    in property <string> label;
    in property <bool> enabled: true;

    height: 28px;
    background: transparent;
    opacity: root.enabled ? 1.0 : 0.55;

    touch := TouchArea {
        enabled: root.enabled;
        mouse-cursor: root.enabled ? pointer : default;
        clicked => { root.checked = !root.checked; }
    }

    HorizontalLayout {
        spacing: 7px;
        Rectangle {
            width: 20px;
            height: 20px;
            border-radius: 6px;
            background: root.checked ? #bde8cf : #ffffff;
            border-width: 1px;
            border-color: root.checked ? #68b681 : #e4d8df;
            Text {
                text: root.checked ? "✓" : "";
                color: #266f46;
                font-size: 14px;
                font-weight: 850;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
        }
        Text {
            text: root.label;
            color: #5d5260;
            font-size: 12px;
            font-weight: 650;
            vertical-alignment: center;
            overflow: elide;
        }
    }
}

component MiniInput inherits Rectangle {
    in-out property <string> value;
    in property <string> placeholder;
    in property <bool> enabled: true;

    height: 34px;
    border-radius: 8px;
    background: #fffdfd;
    border-width: 1px;
    border-color: #efdfe6;

    if root.value == "": Text {
        x: 10px;
        y: 0px;
        height: parent.height;
        text: root.placeholder;
        color: #b7a8b3;
        font-size: 12px;
        vertical-alignment: center;
        overflow: elide;
    }

    LineEdit {
        x: 7px;
        y: 2px;
        width: parent.width - 14px;
        height: parent.height - 4px;
        text <=> root.value;
        enabled: root.enabled;
    }
}

export component AppWindow inherits Window {
    in-out property <string> port-text: "";
    in-out property <[string]> port-options: [];
    in-out property <string> file-text: "";
    in-out property <bool> erase-first: true;
    in-out property <bool> verify-status: true;
    in-out property <bool> busy: false;
    in-out property <int> progress: 0;
    in-out property <string> status-text: "Ready";
    in-out property <string> log-text: "Select serial port and merged image.";
    callback browse-file();
    callback scan-ports();
    callback select-port(int);
    callback start-flash();

    title: "MeowWave Flash";
    width: 420px;
    height: 392px;
    background: #fffaf7;

    Rectangle {
        background: #fffaf7;

        VerticalLayout {
            padding: 16px;
            spacing: 10px;

            HorizontalLayout {
                spacing: 10px;

                Rectangle {
                    width: 38px;
                    height: 38px;
                    border-radius: 13px;
                    background: #ffe7ee;
                    border-width: 1px;
                    border-color: #ffd0dc;

                    Text {
                        text: "MW";
                        color: #9b3152;
                        font-size: 15px;
                        font-weight: 850;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }

                VerticalLayout {
                    spacing: 1px;
                    Text {
                        text: "MeowWave Flash";
                        color: #22223a;
                        font-size: 20px;
                        font-weight: 850;
                    }
                    Text {
                        text: "TI mmWave UART image flasher";
                        color: #7b7080;
                        font-size: 11px;
                    }
                }

                Rectangle { horizontal-stretch: 1; }

                Rectangle {
                    width: 92px;
                    height: 30px;
                    border-radius: 15px;
                    background: root.busy ? #fff2cc : #e9f8ef;
                    border-width: 1px;
                    border-color: root.busy ? #efd37a : #badfc8;
                    animate background { duration: 120ms; easing: ease-out; }

                    Text {
                        text: root.status-text;
                        color: root.busy ? #8f6b00 : #246b43;
                        font-size: 12px;
                        font-weight: 760;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                        overflow: elide;
                    }
                }
            }

            Rectangle {
                height: 1px;
                background: #f1dfe6;
            }

            VerticalLayout {
                spacing: 9px;

                Text { text: "Serial"; color: #6f6474; font-size: 10px; font-weight: 740; }
                HorizontalLayout {
                    spacing: 8px;
                    MiniInput {
                        horizontal-stretch: 1;
                        value <=> root.port-text;
                        placeholder: "/dev/cu.usbserial";
                        enabled: !root.busy;
                    }
                    MiniButton {
                        width: 70px;
                        label: "Scan";
                        enabled: !root.busy;
                        clicked => { root.scan-ports(); }
                    }
                }

                if root.port-options.length > 0: Rectangle {
                    height: 60px;
                    border-radius: 8px;
                    background: #fffafd;
                    border-width: 1px;
                    border-color: #f0dfe6;
                    ScrollView {
                        width: parent.width;
                        height: parent.height;
                        VerticalLayout {
                            padding: 5px;
                            spacing: 4px;
                            for port[index] in root.port-options: MiniButton {
                                height: 25px;
                                label: port;
                                active: root.port-text == port;
                                enabled: !root.busy;
                                clicked => { root.select-port(index); }
                            }
                        }
                    }
                }

                Text { text: "Image"; color: #6f6474; font-size: 10px; font-weight: 740; }
                HorizontalLayout {
                    spacing: 8px;
                    MiniInput {
                        horizontal-stretch: 1;
                        value <=> root.file-text;
                        placeholder: "image.bin";
                        enabled: !root.busy;
                    }
                    MiniButton {
                        width: 70px;
                        label: "File";
                        enabled: !root.busy;
                        clicked => { root.browse-file(); }
                    }
                }

                HorizontalLayout {
                    spacing: 16px;
                    MiniToggle {
                        horizontal-stretch: 1;
                        label: "Erase";
                        checked <=> root.erase-first;
                        enabled: !root.busy;
                    }
                    MiniToggle {
                        horizontal-stretch: 1;
                        label: "Verify";
                        checked <=> root.verify-status;
                        enabled: !root.busy;
                    }
                }
            }

            Rectangle {
                height: 9px;
                border-radius: 5px;
                background: #f4edf2;
                Rectangle {
                    height: parent.height;
                    width: root.progress <= 0 ? 0px : max(4px, parent.width * root.progress / 100);
                    border-radius: 5px;
                    background: #ff8ca8;
                    animate width { duration: 150ms; easing: ease-out; }
                }
            }

            Rectangle {
                vertical-stretch: 1;
                border-radius: 9px;
                background: #fffafd;
                border-width: 1px;
                border-color: #f0dfe6;

                Text {
                    x: 10px;
                    y: 9px;
                    width: parent.width - 20px;
                    height: parent.height - 18px;
                    text: root.log-text;
                    color: #51495a;
                    font-size: 12px;
                    wrap: word-wrap;
                    vertical-alignment: top;
                }
            }

            MiniButton {
                height: 40px;
                label: root.busy ? "Flashing..." : "Flash";
                enabled: !root.busy;
                clicked => { root.start-flash(); }
            }
        }
    }
}
